# =====================
# 管理后台环境变量配置示例
# 复制本文件为 .env.local 并填入实际值
# =====================

# API 基础地址
VITE_API_BASE_URL=http://localhost:8080

# 后端服务地址
VITE_BACKEND_URL=http://localhost:8080

# 管理员密钥/令牌（如需）
VITE_ADMIN_TOKEN=your_admin_token_here

# 应用名称
VITE_APP_NAME=Tilex Blog Admin

# 是否显示调试信息
VITE_DEBUG=false
